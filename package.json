    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.25.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
